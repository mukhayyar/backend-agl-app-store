# ── Domain ────────────────────────────────────────────────────────────────
DOMAIN=agl-store.cyou

# ── Database ──────────────────────────────────────────────────────────────
DB_USER=pensagl
DB_PASSWORD=changeme_strong_password

# ── Flat-manager ──────────────────────────────────────────────────────────
# Base64-encoded JWT signing secret (used inside config.json)
FLAT_MANAGER_SECRET_B64=changeme_base64_secret
# Plain JWT signing secret (used in rest_api.py / gentoken)
FLAT_MANAGER_SECRET=changeme_plain_secret
# Admin JWT token (generated by setup.sh, do not set manually)
FLAT_MANAGER_ADMIN_TOKEN=
# OSTree repo name shown to flatpak clients
FLATPAK_REPO_NAME=agl-store
# GPG key ID for OSTree signing (generated by setup.sh)
GPG_KEY_ID=

# ── Flatpak repo path ─────────────────────────────────────────────────────
# Bind-mount path on the host for the OSTree repository
FLATPAK_REPO_PATH=/srv/flatpak-repo

# ── API / Auth ────────────────────────────────────────────────────────────
API_SECRET=changeme_api_secret
# 64-char random string for JWT user session signing
JWT_SECRET_KEY=changeme_jwt_secret_64_chars_long_please_use_openssl_rand_hex_32

# ── Email (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@mail.agl-store.cyou
ADMIN_EMAIL=admin@example.com

# ── GitHub OAuth ──────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Telegram notifications ────────────────────────────────────────────────
PENSSTORE_BOT_TOKEN=
PENSSTORE_DEVELOPER_CHAT_ID=

# ── Webhook deploy bot ────────────────────────────────────────────────────
WEBHOOK_SECRET=changeme_webhook_secret

# ── Docker project name ───────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=agl
