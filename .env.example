# Database
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/agl_store

# Docker Compose Postgres (used by docker-compose.yml)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=agl_store

# Server Ports
HTTP_HOST=0.0.0.0
HTTP_PORT=8000
GRPC_HOST=0.0.0.0
GRPC_PORT=50051
MAX_WORKERS=10

# CORS (comma-separated origins — REQUIRED in production, e.g. "https://app.example.com")
CORS_ORIGINS=

# Auth (for OAuth providers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# Stripe (for payments)
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# flat-manager Configuration
FLAT_MANAGER_URL=http://localhost:8080
FLAT_MANAGER_API_URL=http://localhost:8080/api/v1
FLAT_MANAGER_REPO=stable
FLAT_MANAGER_BRANCH=stable
FLAT_MANAGER_SECRET=
FLAT_MANAGER_GENTOKEN_PATH=gentoken

# Flathub Proxy Configuration
FLATHUB_API_URL=https://flathub.org/api/v2

# JWT Configuration (REQUIRED — generate a strong random key!)
# Example: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Upload limits
MAX_UPLOAD_SIZE_MB=500
